# === Gutenberg Configuration ===

# Ollama
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_LLM_MODEL=llama3.1:8b-instruct-q4_K_M
OLLAMA_EMBED_MODEL=nomic-embed-text

# ChromaDB
CHROMA_HOST=http://chromadb:8000
CHROMA_COLLECTION=gutenberg

# Gutenberg API
API_PORT=8000
RETRIEVAL_TOP_K=10
RETRIEVAL_CANDIDATE_K=200

# Chunking
CHUNK_SIZE=384
CHUNK_OVERLAP=96
CONTEXT_TOKEN_BUDGET=80

# Contextual chunking (Anthropic's Contextual Retrieval)
CONTEXTUAL_CHUNKER_ENABLED=true

# BM25 index persistence (empty = in-memory only)
BM25_PERSIST_PATH=/data/bm25_index.pkl

# RRF fusion weights (adaptive mode overrides these per-query)
RRF_ADAPTIVE=true
RRF_DENSE_WEIGHT=0.6
RRF_SPARSE_WEIGHT=0.4

# OCR preprocessing (scanned PDFs)
OCR_REMOVE_BG=false

# HyDE (disabled by default — harmful for verbatim citation retrieval)
HYDE_ENABLED=false


# Query result cache (LRU, TTL in seconds)
QUERY_CACHE_MAX_SIZE=100
QUERY_CACHE_TTL=300

# Embedding vector cache (LRU)
EMBED_CACHE_MAX_SIZE=200

# Conversation history token budget for LLM
MAX_HISTORY_TOKENS=2048

# Request-level retrieval metrics logging
LOG_RETRIEVAL_METRICS=true

# Paths (inside containers)
INBOX_DIR=/data/inbox
PROCESSING_DIR=/data/processing
PROCESSED_DIR=/data/processed
FAILED_DIR=/data/failed
STATE_FILE=/data/state/documents.jsonl

# LibreChat
LIBRECHAT_PORT=3080
MONGO_URI=mongodb://mongodb:27017/librechat

# OpenRouter (optional cloud fallback)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-r1
LLM_BACKEND=ollama
RUNPOD_API_KEY=
OCR_BACKEND=auto

# Database
DATABASE_PATH=/data/gutenborg.db
